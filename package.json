{
  "name": "@itiana/dashboard-kit",
  "version": "0.1.0",
  "description": "Real-time dashboard component library with SSE, draggable grid, KPI cards and live charts",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src __tests__ --ext .ts,.tsx"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "react-grid-layout": "^1.4.4",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/react-grid-layout": "^1.3.5",
    "@vitejs/plugin-react": "^4.3.1",
    "jsdom": "^24.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vite-plugin-dts": "^3.9.1",
    "vitest": "^2.0.4"
  },
  "keywords": [
    "dashboard",
    "real-time",
    "sse",
    "kpi",
    "charts",
    "react",
    "typescript",
    "widgets",
    "monitoring",
    "analytics"
  ],
  "author": "itiana",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tiana-code/dashboard-kit.git"
  }
}
